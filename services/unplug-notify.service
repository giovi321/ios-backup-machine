[Unit]
Description=Stop a running backup when the iPhone is unplugged

[Service]
Type=oneshot
User=root
WorkingDirectory=/root/iosbackupmachine
ExecStart=/root/iosbackupmachine/unplug-notify.sh
StandardOutput=append:/var/log/iosbackupmachine/autostart.log
StandardError=append:/var/log/iosbackupmachine/autostart.log
Environment=IOSBACKUP_CONFIG=/root/iosbackupmachine/config.yaml
