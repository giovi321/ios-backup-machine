# /root/iosbackupmachine/config.yaml
# config_version is managed automatically; do not edit by hand.
config_version: 1
setup_completed: false
backup_dir: /media/iosbackup/
marker_file: .foldermarker
disk_device: /dev/mmcblk1
orientation: landscape_right
font_path: "/root/iosbackupmachine/UbuntuMono-Regular.ttf"
owner_lines:
  - "Property of Titius Caius"
  - "+33 123 456 7890"
  - "write@titiuscaius.com"
  - "Reward if found €€€"
error_codes:
  "100": "Snapshot failure at path"
  "102": "iPhone out of space. Free space on iPhone and retry."
  "103": "Backup directory is wrong"
  "105": "Insufficient free disk space on backup drive"
  "106": "No space left for the backup"
  "208": "Unlock iPhone and try again"
  "-4":  "iPhone disconnected during backup"

# --- Authentication ---
auth:
  password_hash: ""  # SHA-256 salted hash; empty = no auth required (set via web UI)

# --- Backup behavior ---
backup:
  auto_start: true          # start backup automatically when iPhone is plugged in
  notify_on_rejected: true   # send notification when a non-allowed device is rejected

# --- Backup encryption ---
# Encryption is set ON THE iPHONE via the web UI Encryption page.
# The password is NEVER stored on this device — you must remember it
# yourself (it is only needed to restore backups).
backup_encryption:
  encryption_confirmed: false   # set true once encryption has been verified enabled on a device

# --- Device filter ---
device_filter:
  enabled: false             # if true, only UDIDs in allowed_udids can trigger backup
  allowed_devices: []        # list of {udid: "...", name: "..."} dicts
  # Example:
  # allowed_devices:
  #   - udid: "00008030-001A34E22.."
  #     name: "John's iPhone 15"

# --- WiFi settings ---
# Configure one or more networks; the device connects to whichever is in range.
# Networks are tried in list order (first = preferred). ssid/password below are
# the legacy single-network fields, kept mirrored to networks[0] for back-compat.
wifi:
  enabled: false
  ssid: ""
  password: ""
  networks: []
  #  - nickname: "Home"
  #    ssid: "HomeNetwork"
  #    password: "secret"
  #  - nickname: "Office"
  #    ssid: "CorpWiFi"
  #    password: "another-secret"

# --- NTP time sync ---
ntp:
  enabled: true
  servers:
    - "pool.ntp.org"
    - "time.google.com"

# --- Web UI ---
webui:
  enabled: true
  port: 8080
  # Which interfaces the web UI listens on: wifi, usb_iphone, all
  bind_interfaces:
    - "all"
  secret_key: "change-me-to-a-random-string"

# --- Notifications ---
notifications:
  webhook:
    enabled: false
    url: ""
    # Events: backup_start, backup_complete, backup_error, device_connected, device_disconnected, device_rejected
    events:
      - "backup_complete"
      - "backup_error"
    # Optional auth header. The header VALUE is encrypted at rest in notify.enc
    # (same AES-256-GCM credential store as WireGuard/sync). Set the value via the
    # web UI. In UDID mode it can only be decrypted while the iPhone is connected,
    # so events fired without a device go out unauthenticated.
    auth_enabled: false
    auth_header: "Authorization"
  mqtt:
    enabled: false
    broker: ""
    port: 1883
    username: ""
    password: ""
    topic_prefix: "iosbackupmachine"
    events:
      - "backup_complete"
      - "backup_error"

# --- WireGuard client ---
wireguard:
  enabled: false
  interface_name: "wg0"
  # WireGuard config is stored encrypted in /root/iosbackupmachine/wireguard.enc
  # The encryption key is derived from the connected iPhone's UUID

# --- Credential encryption (WireGuard + remote sync) ---
credential_encryption:
  passphrase_mode: udid   # "udid" (auto-decrypt when iPhone connected) or "custom"

# --- Remote sync (rsync over SSH) ---
sync:
  enabled: false
  auto_sync: false           # sync automatically after each successful backup
  allowed_network: any       # any | wifi | wifi_ssid | usb
  # Power-aware sync: refuse to start (and auto-abort) a sync when not charging
  # and battery is below this percent. Kept above PiSugar's 30% auto-shutdown so
  # a long rsync isn't cut mid-transfer. SSH credentials live encrypted in sync.enc.
  min_battery_percent: 35
