#!/bin/bash
# NetworkManager dispatcher: auto-connect WireGuard when WiFi comes up
# Installed to /etc/NetworkManager/dispatcher.d/

IFACE="$1"
ACTION="$2"

if [ "$ACTION" = "up" ]; then
    if echo "$IFACE" | grep -q "^wlan"; then
        /root/iosbackupmachine/wg-autoconnect.sh wifi &
    elif echo "$IFACE" | grep -qE "^(usb|eth[1-9]|enx)"; then
        /root/iosbackupmachine/wg-autoconnect.sh iphone &
    fi
fi
